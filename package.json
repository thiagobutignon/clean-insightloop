{
  "name": "insightloop-mcp-server-v2",
  "version": "1.0.0",
  "description": "InsightLoop MCP Server v2 - User Account Management System with Clean Architecture",
  "main": "dist/main.js",
  "scripts": {
    "build": "tsc",
    "start": "node dist/main.js",
    "dev": "ts-node-dev --respawn --transpile-only src/main.ts",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "test:unit": "jest --config ./jest.config.js --testPathPattern=tests/unit",
    "test:integration": "jest --config ./tests/integration/jest.integration.config.js",
    "test:integration:watch": "jest --config ./tests/integration/jest.integration.config.js --watch",
    "test:integration:coverage": "jest --config ./tests/integration/jest.integration.config.js --coverage",
    "test:integration:database": "jest --config ./tests/integration/jest.integration.config.js --testPathPattern=database",
    "test:integration:security": "jest --config ./tests/integration/jest.integration.config.js --testPathPattern=security",
    "test:integration:performance": "jest --config ./tests/integration/jest.integration.config.js --testPathPattern=performance",
    "test:integration:e2e": "jest --config ./tests/integration/jest.integration.config.js --testPathPattern=e2e",
    "test:integration:error-handling": "jest --config ./tests/integration/jest.integration.config.js --testPathPattern=error-handling",
    "test:e2e": "jest --config ./tests/e2e/jest-e2e.json",
    "lint": "eslint src/**/*.ts",
    "lint:fix": "eslint src/**/*.ts --fix",
    "format": "prettier --write src/**/*.ts",
    "migrate": "typeorm migration:run -d src/infrastructure/database/typeorm/typeorm.config.ts",
    "migrate:revert": "typeorm migration:revert -d src/infrastructure/database/typeorm/typeorm.config.ts",
    "migrate:generate": "typeorm migration:generate -d src/infrastructure/database/typeorm/typeorm.config.ts",
    "db:seed": "ts-node src/infrastructure/database/seeds/seed.ts",
    "swagger": "ts-node src/presentation/http/rest/swagger/generate-docs.ts"
  },
  "keywords": [
    "clean-architecture",
    "node.js",
    "typescript",
    "express",
    "postgresql",
    "typeorm",
    "user-management",
    "authentication"
  ],
  "author": "InsightLoop Team",
  "license": "MIT",
  "dependencies": {
    "bcrypt": "^5.1.1",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.0",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "express-rate-limit": "^6.10.0",
    "helmet": "^7.0.0",
    "joi": "^17.9.2",
    "pg": "^8.11.3",
    "redis": "^4.6.8",
    "reflect-metadata": "^0.1.13",
    "swagger-jsdoc": "^6.2.8",
    "swagger-ui-express": "^5.0.0",
    "typeorm": "^0.3.17",
    "uuid": "^9.0.0",
    "winston": "^3.10.0"
  },
  "devDependencies": {
    "@types/bcrypt": "^5.0.0",
    "@types/cors": "^2.8.13",
    "@types/express": "^4.17.17",
    "@types/jest": "^29.5.4",
    "@types/node": "^20.5.0",
    "@types/supertest": "^6.0.3",
    "@types/swagger-jsdoc": "^6.0.1",
    "@types/swagger-ui-express": "^4.1.3",
    "@types/uuid": "^9.0.2",
    "@typescript-eslint/eslint-plugin": "^6.4.0",
    "@typescript-eslint/parser": "^6.4.0",
    "eslint": "^8.47.0",
    "husky": "^8.0.3",
    "jest": "^29.6.2",
    "lint-staged": "^14.0.1",
    "prettier": "^3.0.2",
    "supertest": "^6.3.3",
    "ts-jest": "^29.1.1",
    "ts-node": "^10.9.1",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.1.6"
  },
  "husky": {
    "hooks": {
      "pre-commit": "lint-staged"
    }
  },
  "lint-staged": {
    "*.{ts,js}": [
      "eslint --fix",
      "prettier --write"
    ]
  }
}
