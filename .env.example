# Application Configuration
NODE_ENV=development
PORT=3000
API_VERSION=v1

# Database Configuration
DB_TYPE=postgres
DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=insightloop
DB_PASSWORD=password
DB_DATABASE=insightloop_dev
DB_SYNCHRONIZE=false
DB_LOGGING=true

# Redis Configuration
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# Security Configuration
# =======================================================================
# JWT Secret Configuration - CRITICAL SECURITY SETTINGS
# =======================================================================
#
# 🔐 JWT_SECRET: Used to sign and verify JWT tokens
# 
# ⚠️  SECURITY WARNINGS:
# - NEVER use the default value in production
# - This secret protects ALL user sessions and API access
# - If compromised, attackers can forge valid tokens for any user
# - Store in secure environment variable management system (e.g., AWS Secrets Manager, Azure Key Vault)
#
# 📋 REQUIREMENTS:
# - Minimum 64 characters (256+ characters recommended for production)
# - Use cryptographically secure random generation
# - Include uppercase, lowercase, numbers, and special characters
# - Avoid dictionary words, patterns, or predictable sequences
#
# 🔄 SECRET ROTATION:
# - Rotate every 90 days minimum (30 days recommended for high-security environments)
# - Implement graceful rotation with JWT_SECRET_PREVIOUS for transition periods
# - Coordinate rotation with deployment windows to minimize user disruption
# - Log rotation events for security auditing
#
# 🛠️  SECURE GENERATION EXAMPLES:
# - OpenSSL: openssl rand -base64 64
# - Node.js: require('crypto').randomBytes(64).toString('base64')
# - Python: import secrets; secrets.token_urlsafe(64)
# - Online: Use a reputable password manager's random generator
#
# 📚 REFERENCES:
# - JWT Best Practices: https://tools.ietf.org/html/rfc8725
# - OWASP JWT Security: https://cheatsheetseries.owasp.org/cheatsheets/JSON_Web_Token_for_Java_Cheat_Sheet.html
# - NIST Key Management: https://nvlpubs.nist.gov/nistpubs/SpecialPublications/NIST.SP.800-57pt1r5.pdf
#
JWT_SECRET=your-super-secret-jwt-key-change-in-production-minimum-64-characters-use-cryptographically-secure-random-generation
# JWT_SECRET_PREVIOUS=previous-secret-for-rotation-transition-periods-implement-graceful-key-rotation
JWT_EXPIRES_IN=24h
BCRYPT_SALT_ROUNDS=12

# SSL/TLS Configuration (optional - use if app handles SSL directly)
SSL_ENABLED=false
SSL_KEY_PATH=/path/to/private-key.pem
SSL_CERT_PATH=/path/to/certificate.pem
HTTPS_PORT=443

# Session Configuration (if using sessions)
SESSION_SECRET=your-super-secret-session-key-change-in-production

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# Logging Configuration
LOG_LEVEL=info
LOG_FORMAT=json

# Swagger Configuration
SWAGGER_ENABLED=true
SWAGGER_PATH=/api/docs

# CORS Configuration
CORS_ORIGIN=http://localhost:3000
CORS_CREDENTIALS=true

# External API Keys (uncomment and configure as needed for production)
# AWS_ACCESS_KEY_ID=your-aws-access-key
# AWS_SECRET_ACCESS_KEY=your-aws-secret-key
# SENDGRID_API_KEY=your-sendgrid-api-key
# STRIPE_SECRET_KEY=your-stripe-secret-key
# GOOGLE_CLIENT_SECRET=your-google-client-secret
# GITHUB_CLIENT_SECRET=your-github-client-secret

# Application Metadata
APP_VERSION=1.0.0
API_BASE_URL=http://localhost:3000